{
  "schema": "ravi.app/v1",
  "id": "console/control",
  "name": "Console Backoffice",
  "version": "0.1.0",
  "description": "Internal operator app for Ravi Console user control, organization backoffice, feature access, support intake, and product diagnostics.",
  "interfaces": {
    "cli": {
      "command": "ravi console control",
      "json": true,
      "health": "ravi apps run console/control check --json"
    },
    "sdk": {
      "namespace": "consoleControl"
    },
    "stream": {
      "channels": ["ravi.console.control.events"]
    },
    "ui": {
      "routes": [
        {
          "id": "main",
          "path": "/apps/console/control",
          "label": "Console Backoffice",
          "icon": "building-2",
          "view": "overview",
          "permission": "console.internal_control"
        }
      ],
      "views": [
        {
          "id": "overview",
          "type": "dashboard",
          "title": "Console Backoffice",
          "density": "compact",
          "query": {
            "operation": "console.control.overview"
          },
          "refreshOn": [
            "ravi.console.control.changed",
            "ravi.console.users.changed",
            "ravi.console.organizations.changed",
            "ravi.console.features.changed",
            "ravi.console.pages.domain.changed",
            "ravi.console.organization.access.changed"
          ],
          "actions": [
            {
              "id": "check",
              "label": "Check",
              "icon": "shield-check",
              "operation": "console.control.check",
              "placement": "toolbar"
            },
            {
              "id": "identity",
              "label": "Identity",
              "icon": "badge-check",
              "operation": "console.control.me",
              "placement": "toolbar"
            },
            {
              "id": "users",
              "label": "Users",
              "icon": "users",
              "operation": "console.control.users",
              "placement": "toolbar",
              "permission": "console.users.read"
            },
            {
              "id": "orgs",
              "label": "Organizations",
              "icon": "building-2",
              "operation": "console.control.organizations",
              "placement": "toolbar",
              "permission": "console.organizations.read"
            },
            {
              "id": "features",
              "label": "Features",
              "icon": "key-round",
              "operation": "console.control.feature-access",
              "placement": "toolbar",
              "permission": "console.features.read"
            },
            {
              "id": "projects",
              "label": "Projects",
              "icon": "folder-kanban",
              "operation": "console.control.projects",
              "placement": "toolbar",
              "permission": "console.projects.read"
            }
          ],
          "layout": {
            "areas": ["users", "organizations", "features", "access", "products", "audit"]
          },
          "components": [
            {
              "id": "users",
              "type": "summary",
              "title": "Users",
              "source": "future:/api/cli/internal/control/users"
            },
            {
              "id": "organizations",
              "type": "summary",
              "title": "Organizations",
              "source": "future:/api/cli/internal/control/orgs"
            },
            {
              "id": "feature-access",
              "type": "summary",
              "title": "Feature access",
              "source": "/api/cli/internal/control/features"
            },
            {
              "id": "access-intake",
              "type": "summary",
              "title": "Access intake",
              "source": "future:/api/cli/internal/control/access-requests"
            },
            {
              "id": "pages-diagnostics",
              "type": "summary",
              "title": "Pages diagnostics",
              "source": "future:/api/cli/internal/control/pages/diagnostics"
            },
            {
              "id": "operator-audit",
              "type": "timeline",
              "title": "Operator audit",
              "source": "future:/api/cli/internal/control/audit"
            }
          ]
        }
      ]
    }
  },
  "operations": {
    "console.control.help": {
      "interface": "builtin",
      "handler": "apps.help",
      "mutating": false
    },
    "console.control.show": {
      "interface": "builtin",
      "handler": "apps.manifest.show",
      "mutating": false
    },
    "console.control.overview": {
      "interface": "builtin",
      "handler": "apps.stub.list",
      "mutating": false,
      "outputSchema": "schemas/console-control-overview.v1.json"
    },
    "console.control.check": {
      "interface": "builtin",
      "handler": "apps.manifest.check",
      "mutating": false,
      "outputSchema": "schemas/console-control-check.v1.json"
    },
    "console.control.me": {
      "interface": "cli",
      "command": "ravi whoami --json",
      "mutating": false,
      "outputSchema": "schemas/console-control-me.v1.json",
      "aliases": ["identity", "whoami"]
    },
    "console.control.users": {
      "interface": "builtin",
      "handler": "apps.stub.list",
      "mutating": false,
      "permission": "console.users.read",
      "outputSchema": "schemas/console-control-users.v1.json"
    },
    "console.control.organizations": {
      "interface": "builtin",
      "handler": "apps.stub.list",
      "mutating": false,
      "permission": "console.organizations.read",
      "outputSchema": "schemas/console-control-organizations.v1.json",
      "aliases": ["orgs"]
    },
    "console.control.feature-access": {
      "interface": "builtin",
      "handler": "apps.stub.list",
      "mutating": false,
      "permission": "console.features.read",
      "outputSchema": "schemas/console-control-feature-access.v1.json",
      "aliases": ["features", "entitlements"]
    },
    "console.control.access-requests": {
      "interface": "builtin",
      "handler": "apps.stub.list",
      "mutating": false,
      "permission": "console.control.read",
      "outputSchema": "schemas/console-control-access-requests.v1.json",
      "aliases": ["requests"]
    },
    "console.control.projects": {
      "interface": "cli",
      "command": "ravi cloud projects list --json",
      "mutating": false,
      "permission": "console.projects.read",
      "outputSchema": "schemas/console-control-projects.v1.json"
    },
    "console.control.pages-sites": {
      "interface": "cli",
      "command": "ravi pages list {args} --json",
      "mutating": false,
      "permission": "console.pages.read",
      "outputSchema": "schemas/console-control-pages-sites.v1.json",
      "aliases": ["pages", "sites"]
    },
    "console.control.pages-diagnostics": {
      "interface": "builtin",
      "handler": "apps.stub.list",
      "mutating": false,
      "permission": "console.pages.read",
      "outputSchema": "schemas/console-control-pages-diagnostics.v1.json",
      "aliases": ["pages-diag", "domain-diag"]
    },
    "console.control.audit": {
      "interface": "builtin",
      "handler": "apps.stub.list",
      "mutating": false,
      "permission": "console.audit.read",
      "outputSchema": "schemas/console-control-audit.v1.json"
    },
    "console.control.events": {
      "interface": "stream",
      "channel": "ravi.console.control.events",
      "mutating": false,
      "outputSchema": "events/console-control-event.v1.json"
    }
  },
  "permissions": {
    "required": ["console.internal_control", "console.control.read"],
    "optional": [
      "console.users.read",
      "console.organizations.read",
      "console.features.read",
      "console.projects.read",
      "console.pages.read",
      "console.audit.read",
      "console.channels.read",
      "console.connectors.read"
    ],
    "mutating": [
      "console.control.write",
      "console.users.manage",
      "console.organizations.manage",
      "console.features.manage",
      "console.pages.manage"
    ]
  },
  "storage": {
    "sqlite": [],
    "files": []
  },
  "artifacts": [],
  "events": {
    "emits": [
      {
        "topic": "ravi.console.control.changed",
        "when": "Console operator-visible state changes",
        "durability": "logged",
        "schema": "events/console-control-changed.v1.json"
      }
    ],
    "consumes": [
      {
        "topic": "ravi.console.pages.domain.changed",
        "interface": "stream",
        "durability": "logged",
        "schema": "events/console-pages-domain-changed.v1.json"
      },
      {
        "topic": "ravi.console.users.changed",
        "interface": "stream",
        "durability": "logged",
        "schema": "events/console-users-changed.v1.json"
      },
      {
        "topic": "ravi.console.organizations.changed",
        "interface": "stream",
        "durability": "logged",
        "schema": "events/console-organizations-changed.v1.json"
      },
      {
        "topic": "ravi.console.features.changed",
        "interface": "stream",
        "durability": "logged",
        "schema": "events/console-features-changed.v1.json"
      },
      {
        "topic": "ravi.console.organization.access.changed",
        "interface": "stream",
        "durability": "logged",
        "schema": "events/console-organization-access-changed.v1.json"
      }
    ]
  },
  "skills": ["ravi-system-console-control", "ravi-system-apps", "ravi-system-permissions-manager"],
  "health": {
    "checks": [
      {
        "type": "builtin",
        "handler": "apps.manifest.check"
      }
    ]
  },
  "versioning": {
    "compatibility": "semver",
    "migrations": []
  }
}
