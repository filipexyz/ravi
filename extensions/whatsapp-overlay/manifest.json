{
  "manifest_version": 3,
  "name": "Ravi WhatsApp Overlay",
  "version": "0.1.0",
  "description": "Sobrepoe estado operacional do Ravi no WhatsApp Web.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://127.0.0.1:4210/*",
    "http://localhost:4210/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "task-duration.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js"
      ],
      "matches": [
        "https://web.whatsapp.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Ravi WhatsApp Overlay"
  }
}
