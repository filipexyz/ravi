{
  "manifest_version": 3,
  "name": "Ravi WhatsApp Overlay",
  "version": "0.1.0",
  "description": "Sobrepoe estado operacional do Ravi no WhatsApp Web.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://storage.googleapis.com/*",
    "https://*.elevenlabs.io/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';",
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval'; worker-src 'self' blob:; child-src 'self'; object-src 'none';"
  },
  "sandbox": {
    "pages": [
      "vibes-sandbox.html"
    ]
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "task-duration.js",
        "task-presenter.js",
        "task-drawer-state.js",
        "vibes.js",
        "content.js"
      ],
      "css": [
        "styles.css",
        "theme-nubank.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js",
        "vibes-sandbox.html",
        "vibes-sandbox.js",
        "vendor/strudel/index.js",
        "vendor/strudel/assets/*",
        "vendor/strudel/LICENSE"
      ],
      "matches": [
        "https://web.whatsapp.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Ravi WhatsApp Overlay"
  }
}
