#!/usr/bin/env bash
# Pre-push hook: mirror CI locally before remote failures.

set -euo pipefail

if ! command -v bun >/dev/null 2>&1; then
  echo "bun is required for pre-push checks." >&2
  exit 1
fi

echo "Running pre-push checks..."

run_local_check() {
  env \
    -u RAVI_ACCOUNT_ID \
    -u RAVI_ACTOR_AGENT_ID \
    -u RAVI_ACTOR_TYPE \
    -u RAVI_AGENT_ID \
    -u RAVI_CANONICAL_CHAT_ID \
    -u RAVI_CHANNEL \
    -u RAVI_CHAT_ID \
    -u RAVI_CONTACT_ID \
    -u RAVI_CONTEXT_KEY \
    -u RAVI_GROUP_ID \
    -u RAVI_GROUP_NAME \
    -u RAVI_INSTANCE_ID \
    -u RAVI_NORMALIZED_SENDER_ID \
    -u RAVI_PLATFORM_IDENTITY_ID \
    -u RAVI_RAW_SENDER_ID \
    -u RAVI_SENDER_ID \
    -u RAVI_SENDER_NAME \
    -u RAVI_SENDER_PHONE \
    -u RAVI_SESSION_KEY \
    -u RAVI_SESSION_NAME \
    -u RAVI_TURN_SCOPED_AUTHORITY \
    "$@"
}

echo "Checking generated SDK drift..."
if ! run_local_check bun run sdk:check; then
  echo ""
  echo "SDK drift detected. Regenerating generated client files..."
  if ! run_local_check bun run sdk:generate; then
    echo "Failed to regenerate SDK client." >&2
    exit 1
  fi
  echo ""
  echo "Generated SDK client changed. Review and commit these files, then push again:"
  echo "  packages/ravi-os-sdk/src/client.ts"
  echo "  packages/ravi-os-sdk/src/schemas.ts"
  echo "  packages/ravi-os-sdk/src/types.ts"
  echo "  packages/ravi-os-sdk/src/version.ts"
  exit 1
fi

echo "Running build..."
run_local_check bun run build

echo "Running typecheck..."
run_local_check bun run typecheck

echo "Running tests..."
run_local_check bun run test

echo "Pre-push checks passed."
